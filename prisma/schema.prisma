// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Filme {
  id     Int    @id
  titulo String
  poster String

  sessoes Sessao[]
}

model Sessao {
  id      String   @id @default(cuid())
  filmeId Int
  data    DateTime // representa o dia (ou até horário, se quiser depois)

  filme Filme @relation(fields: [filmeId], references: [id])

  reservas Reserva[]

  @@unique([filmeId, data]) // um filme só tem 1 sessão por data
}

model Reserva {
  id        String   @id @default(cuid())
  usuarioId String   // Clerk
  sessaoId  String
  cadeira   Int      // 1 a 30

  criadoEm DateTime @default(now())

  sessao Sessao @relation(fields: [sessaoId], references: [id])

  @@unique([sessaoId, cadeira]) // 🔥 trava cadeira por data
}